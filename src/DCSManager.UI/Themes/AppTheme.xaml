<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tb="http://www.hardcodet.net/taskbar"
                    xmlns:conv="clr-namespace:DCSManager.UI.Converters">

    <!-- Converters -->
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:BoolInvertConverter x:Key="BoolInvertConverter"/>
    <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    <conv:BoolToSuccessConverter x:Key="BoolToSuccessConverter"/>

    <!-- System Tray Icon (no event handlers — wired in code-behind) -->
    <tb:TaskbarIcon x:Key="TrayIcon"
                    ToolTipText="DCS Manager"
                    IconSource="/DCSManager;component/Assets/tray.ico">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Open DCS Manager" FontWeight="Bold" Tag="open"/>
                <Separator/>
                <MenuItem Header="Check for Updates Now" Tag="check"/>
                <Separator/>
                <MenuItem Header="Exit" Tag="exit"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

</ResourceDictionary>
