<Window x:Class="DCSManager.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DCSManager.UI.Views"
        Title="DCS Manager" Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="#FF1A1A2E"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="NavBg" Color="#FF16213E"/>
        <SolidColorBrush x:Key="ContentBg" Color="#FF1A1A2E"/>
        <SolidColorBrush x:Key="CardBg" Color="#FF0F3460"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FFFFC107"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#FF2196F3"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFF44336"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9E9E9E"/>

        <!-- Nav Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" BasedOn="{StaticResource NavButton}" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update Button -->
        <Style x:Key="UpdateButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentYellow}"/>
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="PluginCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- TextBox Search Style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF0F3460"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Badge Style -->
        <Style x:Key="UpdateBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentYellow}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT NAVIGATION ===== -->
        <Border Grid.Column="0" Background="{StaticResource NavBg}">
            <DockPanel>
                <!-- Logo / Title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="DCS" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="Plugin Manager" FontSize="13"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <!-- DCS Status Indicator -->
                <Border DockPanel.Dock="Top" Margin="12,0,12,16" CornerRadius="4" Padding="10,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#22F44336"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                    <Setter Property="Background" Value="#224CAF50"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentRed}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="DCS Not Running"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                            <Setter Property="Text" Value="DCS Running"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Nav Buttons -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="🔌  Plugins" Style="{StaticResource NavButton}"
                            Click="NavPlugins_Click" Tag="Plugins" x:Name="BtnPlugins"/>
                    <Button Click="NavUpdates_Click" Tag="Updates" x:Name="BtnUpdates">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavButton}" TargetType="Button"/>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄  Updates" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource UpdateBadge}" Margin="8,0,0,0"
                                    Visibility="{Binding PendingUpdateCount, Converter={StaticResource CountToVisibilityConverter}}">
                                <TextBlock Text="{Binding PendingUpdateCount}" FontSize="11"
                                           Foreground="#FF1A1A1A" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Content="📋  History" Style="{StaticResource NavButton}"
                            Click="NavHistory_Click" Tag="History" x:Name="BtnHistory"/>
                    <Button Content="⚙️  Settings" Style="{StaticResource NavButton}"
                            Click="NavSettings_Click" Tag="Settings" x:Name="BtnSettings"/>
                </StackPanel>

                <!-- Bottom: version + check now -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,16">
                    <Button Content="Check for Updates" Style="{StaticResource PrimaryButton}"
                            Command="{Binding CheckNowCommand}"
                            IsEnabled="{Binding IsChecking, Converter={StaticResource BoolInvertConverter}}"/>
                    <TextBlock Text="{Binding LastCheckedText}" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== CONTENT AREA ===== -->
        <Grid Grid.Column="1" Margin="0">
            <!-- Plugins Tab -->
            <Grid x:Name="TabPlugins" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Plugins" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding Plugins.Count, StringFormat=' ({0})'}"
                               FontSize="16" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox Style="{StaticResource SearchBox}" Width="220"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="TbSearch">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <ComboBox Margin="12,0,0,0" Width="160"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Background="#FF0F3460" Foreground="{StaticResource TextPrimary}"
                              BorderBrush="#44FFFFFF" Padding="8,4"/>
                </StackPanel>

                <!-- Plugin List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredPlugins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <Border.Style>
                                        <Style BasedOn="{StaticResource PluginCard}" TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentYellow}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <!-- Name + badges -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Definition.DisplayName}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <Border Margin="8,0,0,0" CornerRadius="3" Padding="5,1"
                                                        Background="#33FFFFFF"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Definition.Category}"
                                                               FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                                </Border>
                                                <Border Margin="6,0,0,0" CornerRadius="3" Padding="5,1"
                                                        Background="{StaticResource AccentYellow}"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="UPDATE AVAILABLE" FontSize="10"
                                                               Foreground="#FF1A1A1A" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- Description -->
                                            <TextBlock Text="{Binding Definition.Description}"
                                                       FontSize="12" Foreground="{StaticResource TextSecondary}"
                                                       TextWrapping="Wrap" Margin="0,0,0,4" MaxWidth="600"/>
                                            <!-- Deprecation warning -->
                                            <TextBlock Text="{Binding Definition.DeprecationNotice}"
                                                       FontSize="12" Foreground="{StaticResource AccentYellow}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding IsDeprecated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <!-- Version status -->
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                            <!-- Progress bar (during install) -->
                                            <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Margin="0,8,0,0">
                                                <ProgressBar Value="{Binding InstallProgress}" Maximum="100"
                                                             Height="6" Background="#22FFFFFF"
                                                             Foreground="{StaticResource AccentBlue}"/>
                                                <TextBlock Text="{Binding InstallStage}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Action Button -->
                                        <Button Grid.Column="1" Content="{Binding ActionLabel}"
                                                VerticalAlignment="Center" MinWidth="130"
                                                IsEnabled="{Binding IsInstalling, Converter={StaticResource BoolInvertConverter}}"
                                                Command="{Binding InstallCommand}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentYellow}"/>
                                                            <Setter Property="Foreground" Value="#FF1A1A1A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsManualOnly}" Value="True">
                                                            <Setter Property="Background" Value="#FF555555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Updates Tab -->
            <Grid x:Name="TabUpdates" Margin="24" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Updates" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                <!-- DCS Running Banner -->
                <Border Grid.Row="1" Background="#22FFC107" CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding IsDcsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Foreground="{StaticResource AccentYellow}" FontSize="13">
                            DCS is currently running. Updates are queued and will be applied automatically when you close DCS.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Apply All Button -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="Apply All Updates" Style="{StaticResource UpdateButton}"
                            Command="{Binding ApplyAllUpdatesCommand}"
                            IsEnabled="{Binding IsDcsRunning, Converter={StaticResource BoolInvertConverter}}"/>
                    <TextBlock Text="{Binding PendingUpdateCount, StringFormat='{}{0} update(s) available'}"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                               Margin="12,0,0,0" FontSize="13"/>
                </StackPanel>

                <!-- Pending Updates List -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredPlugins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PluginCard}"
                                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Definition.DisplayName}" FontSize="15"
                                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0">
                                                <Run Text="{Binding InstalledVersion}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding LatestVersion}" Foreground="{StaticResource AccentGreen}"/>
                                            </TextBlock>
                                            <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Margin="0,8,0,0">
                                                <ProgressBar Value="{Binding InstallProgress}" Maximum="100"
                                                             Height="6" Background="#22FFFFFF"
                                                             Foreground="{StaticResource AccentBlue}"/>
                                                <TextBlock Text="{Binding InstallStage}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Apply Now"
                                                Style="{StaticResource UpdateButton}"
                                                VerticalAlignment="Center"
                                                Command="{Binding InstallCommand}"
                                                IsEnabled="{Binding IsInstalling, Converter={StaticResource BoolInvertConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- History Tab -->
            <Grid x:Name="TabHistory" Margin="24" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Update History" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding History}" AutoGenerateColumns="False"
                          Background="{StaticResource CardBg}" Foreground="{StaticResource TextPrimary}"
                          BorderBrush="#22FFFFFF" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#22FFFFFF" RowBackground="{StaticResource CardBg}"
                          AlternatingRowBackground="#0FFFFFFF" IsReadOnly="True"
                          ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                        <DataGridTextColumn Header="Plugin" Binding="{Binding PluginId}" Width="160"/>
                        <DataGridTextColumn Header="From" Binding="{Binding FromVersion}" Width="100"/>
                        <DataGridTextColumn Header="To" Binding="{Binding ToVersion}" Width="100"/>
                        <DataGridTextColumn Header="Status" Width="80">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Success" Converter="{StaticResource BoolToSuccessConverter}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Details" Binding="{Binding ErrorMessage}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Settings Tab -->
            <ScrollViewer x:Name="TabSettings" Margin="24" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,24"/>

                    <!-- DCS Installations -->
                    <TextBlock Text="DCS Installations" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding DcsInstalls}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PluginCard}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding InstallPath}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Saved Games: "/>
                                            <Run Text="{Binding SavedGamesPath}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Version: "/>
                                            <Run Text="{Binding Version}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Update Settings -->
                    <TextBlock Text="Update Settings" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,24,0,12"/>
                    <Border Style="{StaticResource PluginCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Check interval (minutes):" FontSize="13"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                                           Width="200"/>
                                <TextBox Text="{Binding UpdateIntervalMinutes}" Width="60" FontSize="13"
                                         Background="#FF0F3460" Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="#44FFFFFF" Padding="6,4"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding StartWithWindows}" FontSize="13"
                                          Foreground="{StaticResource TextPrimary}"
                                          Command="{Binding ToggleStartWithWindowsCommand}"
                                          Content="Start with Windows (minimized to tray)"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Log -->
                    <TextBlock Text="Diagnostics" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,24,0,12"/>
                    <Border Style="{StaticResource PluginCard}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open Log File" Style="{StaticResource PrimaryButton}"
                                    Click="OpenLogFile_Click"/>
                            <Button Content="Open Data Folder" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Click="OpenDataFolder_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
