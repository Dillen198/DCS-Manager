<Window x:Class="DCSManager.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DCSManager.UI.Views"
        xmlns:conv="clr-namespace:DCSManager.UI.Converters"
        Title="DCS Manager" Height="760" Width="1180"
        MinHeight="640" MinWidth="960"
        Background="#FF1E1E2E"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- ═══ Catppuccin-inspired palette ═══ -->
        <SolidColorBrush x:Key="Base"       Color="#FF1E1E2E"/>
        <SolidColorBrush x:Key="Mantle"     Color="#FF181825"/>
        <SolidColorBrush x:Key="Crust"      Color="#FF11111B"/>
        <SolidColorBrush x:Key="Surface0"   Color="#FF313244"/>
        <SolidColorBrush x:Key="Surface1"   Color="#FF45475A"/>
        <SolidColorBrush x:Key="Overlay0"   Color="#FF6C7086"/>
        <SolidColorBrush x:Key="Subtext"    Color="#FFA6ADC8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="Blue"       Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="Green"      Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="Yellow"     Color="#FFF9E2AF"/>
        <SolidColorBrush x:Key="Red"        Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="Peach"      Color="#FFFAB387"/>
        <SolidColorBrush x:Key="Mauve"      Color="#FFCBA6F7"/>
        <SolidColorBrush x:Key="Teal"       Color="#FF94E2D5"/>

        <!-- ═══ Converters ═══ -->
        <BooleanToVisibilityConverter       x:Key="BoolToVisibility"/>
        <conv:BoolInvertConverter           x:Key="BoolInvert"/>
        <conv:CountToVisibilityConverter    x:Key="CountToVis"/>
        <conv:BoolToSuccessConverter        x:Key="BoolToSuccess"/>

        <!-- ═══ Scrollbar ═══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource Surface1}" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Nav Button ═══ -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="{StaticResource Subtext}"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="18,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"                Value="13.5"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Active accent bar (hidden by default) -->
                                <Border x:Name="Accent" Grid.Column="0"
                                        Background="{StaticResource Blue}"
                                        CornerRadius="0,2,2,0" Visibility="Collapsed"
                                        Margin="-18,0,0,0"/>
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"   Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" BasedOn="{StaticResource NavButton}" TargetType="Button">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Background"  Value="#1A89B4FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{StaticResource Blue}"
                                        CornerRadius="0,2,2,0"
                                        Margin="-18,0,0,0"/>
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary Button ═══ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Blue}"/>
            <Setter Property="Foreground"      Value="{StaticResource Crust}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update / warning button -->
        <Style x:Key="UpdateButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Yellow}"/>
        </Style>

        <!-- Ghost / secondary button -->
        <Style x:Key="GhostButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource Subtext}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Surface1}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Surface0}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Input ═══ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Surface0}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Blue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Surface1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource Blue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Section Header ═══ -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="{StaticResource Overlay0}"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
        </Style>

        <!-- ═══ Card ═══ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource Surface0}"/>
            <Setter Property="CornerRadius"  Value="10"/>
            <Setter Property="Padding"       Value="20,16"/>
            <Setter Property="Margin"        Value="0,0,0,10"/>
        </Style>

        <!-- ═══ Badge ═══ -->
        <Style x:Key="CategoryBadge" TargetType="Border">
            <Setter Property="Background"   Value="#22CDD6F4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="7,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ═══ CheckBox ═══ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ████████████████  SIDEBAR  ████████████████ -->
        <Border Grid.Column="0" Background="{StaticResource Mantle}">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,22,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="✈" FontSize="20" Foreground="{StaticResource Blue}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="DCS MANAGER" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                                       LetterSpacing="1"/>
                        </StackPanel>
                        <TextBlock Text="Plugin Updater" FontSize="11"
                                   Foreground="{StaticResource Overlay0}" Margin="28,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Surface0}" Margin="16,0,16,12"/>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                    <Button Click="NavPlugins_Click"  Tag="Plugins"  x:Name="BtnPlugins"
                            Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⬡" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Plugins" FontSize="13.5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="NavUpdates_Click" Tag="Updates" x:Name="BtnUpdates"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↻" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Updates" FontSize="13.5" VerticalAlignment="Center"/>
                            <!-- Badge -->
                            <Border Margin="8,0,0,0" CornerRadius="8" Padding="6,1"
                                    Background="{StaticResource Yellow}"
                                    Visibility="{Binding PendingUpdateCount, Converter={StaticResource CountToVis}}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PendingUpdateCount}" FontSize="11"
                                           Foreground="{StaticResource Crust}" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button Click="NavHistory_Click" Tag="History" x:Name="BtnHistory"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="☰" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="History" FontSize="13.5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="NavSettings_Click" Tag="Settings" x:Name="BtnSettings"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings" FontSize="13.5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom area -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,18">
                    <!-- DCS status pill -->
                    <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1AF38BA8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                        <Setter Property="Background" Value="#1AA6E3A1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Red}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Green}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="12" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="DCS Not Running"/>
                                        <Setter Property="Foreground" Value="{StaticResource Red}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDcsRunning}" Value="True">
                                                <Setter Property="Text"       Value="DCS Running"/>
                                                <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Check for Updates -->
                    <Button Content="Check for Updates" Style="{StaticResource PrimaryButton}"
                            Command="{Binding CheckNowCommand}" Padding="12,9"
                            IsEnabled="{Binding IsChecking, Converter={StaticResource BoolInvert}}"/>
                    <TextBlock Text="{Binding LastCheckedText}" FontSize="11"
                               Foreground="{StaticResource Overlay0}"
                               HorizontalAlignment="Center" Margin="0,7,0,0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ████████████████  CONTENT  ████████████████ -->
        <Grid Grid.Column="1" Background="{StaticResource Base}">

            <!-- ══════ PLUGINS TAB ══════ -->
            <Grid x:Name="TabPlugins" Margin="28,24,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plugins" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Border Background="{StaticResource Surface0}" CornerRadius="8"
                                Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Plugins.Count}" FontSize="12"
                                       Foreground="{StaticResource Subtext}" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Search + Filter -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource InputBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="TbSearch">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Background="{StaticResource Surface0}"
                              Foreground="{StaticResource TextPrimary}"
                              BorderBrush="{StaticResource Surface1}"
                              BorderThickness="1" Padding="10,7">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                                <Setter Property="FontSize"   Value="13"/>
                                <Setter Property="Padding"    Value="10,6"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </Grid>

                <!-- Plugin Cards -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                    <ItemsControl ItemsSource="{Binding FilteredPlugins}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" CornerRadius="10" ClipToBounds="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Surface0}"/>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left accent bar -->
                                        <Border Grid.Column="0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Surface1}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="UpToDate">
                                                            <Setter Property="Background" Value="{StaticResource Green}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                                            <Setter Property="Background" Value="{StaticResource Yellow}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="NotInstalled">
                                                            <Setter Property="Background" Value="{StaticResource Overlay0}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="ManualOnly">
                                                            <Setter Property="Background" Value="{StaticResource Mauve}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Background" Value="{StaticResource Red}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Card content -->
                                        <Grid Grid.Column="1" Margin="18,14,16,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <!-- Name row -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <TextBlock Text="{Binding Definition.DisplayName}"
                                                               FontSize="14.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                    <Border Style="{StaticResource CategoryBadge}" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding Definition.Category}"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Subtext}"/>
                                                    </Border>
                                                    <!-- UPDATE badge -->
                                                    <Border Margin="7,0,0,0" CornerRadius="4" Padding="7,1"
                                                            Background="{StaticResource Yellow}" VerticalAlignment="Center"
                                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="UPDATE" FontSize="10" FontWeight="Bold"
                                                                   Foreground="{StaticResource Crust}"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Description -->
                                                <TextBlock Text="{Binding Definition.Description}"
                                                           FontSize="12" Foreground="{StaticResource Subtext}"
                                                           TextWrapping="Wrap" Margin="0,0,0,6" MaxWidth="580"
                                                           LineHeight="17"/>

                                                <!-- Deprecation notice -->
                                                <Border Background="#22F9E2AF" CornerRadius="5" Padding="10,5"
                                                        Margin="0,0,0,5"
                                                        Visibility="{Binding IsDeprecated, Converter={StaticResource BoolToVisibility}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⚠ " Foreground="{StaticResource Yellow}" FontSize="12"/>
                                                        <TextBlock Text="{Binding Definition.DeprecationNotice}"
                                                                   FontSize="12" Foreground="{StaticResource Yellow}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Version / status -->
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="12"
                                                           Foreground="{StaticResource Overlay0}"/>

                                                <!-- Progress (during install) -->
                                                <StackPanel Margin="0,8,0,0"
                                                            Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibility}}">
                                                    <Grid Margin="0,0,0,4">
                                                        <ProgressBar Value="{Binding InstallProgress}" Maximum="100"
                                                                     Height="5" Background="{StaticResource Surface1}"
                                                                     Foreground="{StaticResource Blue}"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding InstallStage}" FontSize="11"
                                                               Foreground="{StaticResource Subtext}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Action button -->
                                            <Button Grid.Column="1" Content="{Binding ActionLabel}"
                                                    MinWidth="130" VerticalAlignment="Center"
                                                    Command="{Binding InstallCommand}"
                                                    IsEnabled="{Binding IsInstalling, Converter={StaticResource BoolInvert}}">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Yellow}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource Crust}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsManualOnly}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Surface1}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="UpToDate">
                                                                <Setter Property="Background" Value="{StaticResource Surface1}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ══════ UPDATES TAB ══════ -->
            <Grid x:Name="TabUpdates" Margin="28,24,28,24" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Updates" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Apply All Updates"
                            Style="{StaticResource UpdateButton}"
                            Command="{Binding ApplyAllUpdatesCommand}"
                            IsEnabled="{Binding IsDcsRunning, Converter={StaticResource BoolInvert}}"/>
                </Grid>

                <!-- DCS Running Banner -->
                <Border Grid.Row="1" Background="#18F9E2AF" CornerRadius="8" Padding="16,11"
                        Margin="0,0,0,14" BorderBrush="#33F9E2AF" BorderThickness="1"
                        Visibility="{Binding IsDcsRunning, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Foreground="{StaticResource Yellow}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Foreground="{StaticResource Yellow}" FontSize="13">
                            DCS is currently running. Updates are queued and will apply automatically when you close DCS.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Count row -->
                <Border Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock FontSize="13" Foreground="{StaticResource Subtext}">
                        <Run Text="{Binding PendingUpdateCount, Mode=OneWay}"/>
                        <Run Text=" update(s) available"/>
                    </TextBlock>
                </Border>

                <!-- Pending list -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredPlugins}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" CornerRadius="10"
                                        Background="{StaticResource Surface0}"
                                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibility}}">
                                    <Grid Margin="18,14,16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Definition.DisplayName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Border Background="{StaticResource Surface1}" CornerRadius="4" Padding="7,2">
                                                    <TextBlock Text="{Binding InstalledVersion}" FontSize="12"
                                                               Foreground="{StaticResource Subtext}"/>
                                                </Border>
                                                <TextBlock Text="  →  " FontSize="13"
                                                           Foreground="{StaticResource Overlay0}"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="#1EA6E3A1" CornerRadius="4" Padding="7,2">
                                                    <TextBlock Text="{Binding LatestVersion}" FontSize="12"
                                                               Foreground="{StaticResource Green}" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibility}}"
                                                        Margin="0,8,0,0">
                                                <ProgressBar Value="{Binding InstallProgress}" Maximum="100"
                                                             Height="5" Background="{StaticResource Surface1}"
                                                             Foreground="{StaticResource Blue}"/>
                                                <TextBlock Text="{Binding InstallStage}" FontSize="11"
                                                           Foreground="{StaticResource Subtext}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Apply Now"
                                                Style="{StaticResource UpdateButton}"
                                                VerticalAlignment="Center"
                                                Command="{Binding InstallCommand}"
                                                IsEnabled="{Binding IsInstalling, Converter={StaticResource BoolInvert}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ══════ HISTORY TAB ══════ -->
            <Grid x:Name="TabHistory" Margin="28,24,28,24" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="History" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                <Border Grid.Row="1" Background="{StaticResource Surface0}" CornerRadius="10" ClipToBounds="True">
                    <DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="{StaticResource TextPrimary}"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Mantle}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#08FFFFFF"
                              IsReadOnly="True" CanUserResizeRows="False"
                              ColumnHeaderHeight="38" SelectionMode="Single"
                              SelectionUnit="FullRow" RowHeight="36">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"  Value="{StaticResource Mantle}"/>
                                <Setter Property="Foreground"  Value="{StaticResource Subtext}"/>
                                <Setter Property="FontSize"    Value="11"/>
                                <Setter Property="FontWeight"  Value="Bold"/>
                                <Setter Property="Padding"     Value="14,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#15CDD6F4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0AFFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="14,0" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIME"   Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd  HH:mm}'}" Width="170"/>
                            <DataGridTextColumn Header="PLUGIN" Binding="{Binding PluginId}"    Width="160"/>
                            <DataGridTextColumn Header="FROM"   Binding="{Binding FromVersion}" Width="110"/>
                            <DataGridTextColumn Header="TO"     Binding="{Binding ToVersion}"   Width="110"/>
                            <DataGridTextColumn Header="STATUS" Width="100">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Success" Converter="{StaticResource BoolToSuccess}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DETAILS" Binding="{Binding ErrorMessage}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ══════ SETTINGS TAB ══════ -->
            <ScrollViewer x:Name="TabSettings" Margin="28,24,28,24"
                          Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,24"/>

                    <!-- DCS Installations -->
                    <TextBlock Text="DCS INSTALLATIONS" Style="{StaticResource SectionHeader}"/>
                    <ItemsControl ItemsSource="{Binding DcsInstalls}" Margin="0,0,0,24">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Colored dot -->
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                Background="#1A89B4FA" CornerRadius="8"
                                                Margin="0,0,14,0">
                                            <TextBlock Text="✈" FontSize="16"
                                                       Foreground="{StaticResource Blue}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource Subtext}" Margin="0,3,0,0">
                                                <Run Text="{Binding InstallPath}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0">
                                                <Run Text="Saved Games: "/>
                                                <Run Text="{Binding SavedGamesPath}" Foreground="{StaticResource Subtext}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0">
                                                <Run Text="Version: "/>
                                                <Run Text="{Binding Version}" Foreground="{StaticResource Subtext}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Update Settings -->
                    <TextBlock Text="UPDATE SETTINGS" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Check Interval" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="How often to check GitHub for new releases" FontSize="12"
                                               Foreground="{StaticResource Subtext}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Text="{Binding UpdateIntervalMinutes}" Width="50"
                                             Style="{StaticResource InputBox}" FontSize="13"
                                             HorizontalContentAlignment="Center"/>
                                    <TextBlock Text=" min" FontSize="13" Foreground="{StaticResource Subtext}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource Surface1}" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start with Windows" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Launch minimized to system tray on Windows startup" FontSize="12"
                                               Foreground="{StaticResource Subtext}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding StartWithWindows}"
                                          VerticalAlignment="Center"
                                          Command="{Binding ToggleStartWithWindowsCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Diagnostics -->
                    <TextBlock Text="DIAGNOSTICS" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Troubleshooting" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open Log File" Style="{StaticResource GhostButton}"
                                        Click="OpenLogFile_Click" Padding="14,8"/>
                                <Button Content="Open Data Folder" Style="{StaticResource GhostButton}"
                                        Margin="10,0,0,0" Click="OpenDataFolder_Click" Padding="14,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
