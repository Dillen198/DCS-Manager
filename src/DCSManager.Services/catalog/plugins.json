{
  "schemaVersion": "1.0",
  "plugins": [
    {
      "id": "srs",
      "displayName": "SimpleRadioStandalone (SRS)",
      "description": "In-cockpit radio simulation for DCS multiplayer. Provides realistic radio communication including frequency management, guard channels, and line-of-sight limitations.",
      "category": "Communication",
      "tags": ["multiplayer", "radio", "voice"],
      "enabled": true,
      "source": {
        "type": "github_release",
        "owner": "ciribob",
        "repo": "DCS-SimpleRadioStandalone"
      },
      "assetSelector": {
        "strategy": "name_regex",
        "pattern": "^SRS-AutoUpdater\\.exe$"
      },
      "installStrategy": {
        "type": "run_installer_exe",
        "silentArgs": "/S",
        "requiresAdmin": true
      },
      "installPaths": [
        {
          "id": "program_files",
          "label": "Program Files",
          "path": "C:\\Program Files\\DCS-SimpleRadio-Standalone",
          "type": "fixed"
        }
      ],
      "versionDetection": {
        "strategy": "exe_file_version",
        "path": "C:\\Program Files\\DCS-SimpleRadio-Standalone\\SR-ClientRadio.exe"
      },
      "homepageUrl": "https://github.com/ciribob/DCS-SimpleRadioStandalone",
      "licenseType": "MIT"
    },
    {
      "id": "dtc",
      "displayName": "DCS Data Transfer Cartridge (DTC)",
      "description": "Pre-flight mission data loading tool. Load waypoints, threat data, and radio presets into compatible aircraft before a mission.",
      "category": "Mission Planning",
      "tags": ["mission", "planning", "data"],
      "enabled": true,
      "source": {
        "type": "github_release",
        "owner": "the-paid-actor",
        "repo": "dcs-dtc"
      },
      "assetSelector": {
        "strategy": "name_regex",
        "pattern": "^.*[Ss]etup.*\\.msi$"
      },
      "installStrategy": {
        "type": "run_installer_msi",
        "requiresAdmin": true
      },
      "installPaths": [
        {
          "id": "program_files_x86",
          "label": "Program Files (x86)",
          "path": "C:\\Program Files (x86)\\DCS-DTC",
          "type": "fixed"
        }
      ],
      "versionDetection": {
        "strategy": "exe_file_version",
        "path": "C:\\Program Files (x86)\\DCS-DTC\\DTC.exe"
      },
      "homepageUrl": "https://github.com/the-paid-actor/dcs-dtc"
    },
    {
      "id": "uh60l",
      "displayName": "UH-60L Black Hawk (Community Mod)",
      "description": "Community-developed UH-60L Black Hawk helicopter mod. Highly detailed cockpit with full systems simulation.",
      "category": "Aircraft Mod",
      "tags": ["helicopter", "transport", "community"],
      "enabled": true,
      "deprecationNotice": "GitHub releases were discontinued after v1.4. v2.0 and above require a manual Patreon download.",
      "source": {
        "type": "github_release",
        "owner": "Kinkkujuustovoileipa",
        "repo": "uh-60l"
      },
      "assetSelector": {
        "strategy": "name_regex",
        "pattern": "^uh-60l-.*\\.zip$"
      },
      "installStrategy": {
        "type": "extract_zip_to_folder",
        "requiresAdmin": false
      },
      "installPaths": [
        {
          "id": "saved_games_stable",
          "label": "DCS Stable",
          "pathTemplate": "{SavedGamesStable}\\Mods\\aircraft\\uh60l",
          "type": "saved_games_relative"
        },
        {
          "id": "saved_games_openbeta",
          "label": "DCS Open Beta",
          "pathTemplate": "{SavedGamesOpenBeta}\\Mods\\aircraft\\uh60l",
          "type": "saved_games_relative"
        }
      ],
      "versionDetection": {
        "strategy": "state_file_only"
      },
      "homepageUrl": "https://github.com/Kinkkujuustovoileipa/uh-60l"
    },
    {
      "id": "tacview",
      "displayName": "Tacview",
      "description": "Flight data recorder and 3D debriefing tool. Record and replay missions to analyse tactics, review engagements, and improve performance.",
      "category": "Analysis",
      "tags": ["debrief", "recording", "analysis"],
      "enabled": true,
      "manualDownloadUrl": "https://www.tacview.net/download/latest/",
      "manualInstallNote": "Tacview has its own installer and update mechanism. Click 'Open Download Page' to get the latest version.",
      "source": {
        "type": "manual_url"
      },
      "assetSelector": {},
      "installStrategy": {
        "type": "open_browser_url",
        "requiresAdmin": false
      },
      "installPaths": [
        {
          "id": "saved_games_stable",
          "label": "DCS Stable",
          "pathTemplate": "{SavedGamesStable}\\Mods\\tech\\Tacview",
          "type": "saved_games_relative"
        }
      ],
      "versionDetection": {
        "strategy": "exe_file_version",
        "path": "C:\\Program Files\\Tacview\\Tacview64.exe"
      },
      "homepageUrl": "https://www.tacview.net"
    }
  ]
}
